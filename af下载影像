// 6. 进阶：按 SHP 要素循环导出 (每个要素一个文件)
// =================================================================

// 将 FeatureCollection 转为 List 方便遍历
var roiList = roi.toList(roi.size());

// 使用 evaluate 在本地触发循环，避免服务器超时
roi.size().evaluate(function(size) {
  for (var i = 0; i < size; i++) {
    var feature = ee.Feature(roiList.get(i));
    var geometry = feature.geometry();
    
    // 获取一个唯一标识符作为文件名（假设属性里有 'system:index' 或 'ID'）
    // 如果你的 shp 有特定 ID 字段，请替换 'system:index'
    var featID = i; 
    
    // 导出文件名
    var exportName = 'Af_Feature_' + featID + '_FullStack_2020';
    
    // 执行导出
    Export.image.toDrive({
      image: finalStack.clip(geometry).unmask(0).multiply(10000).toInt16(),
      description: exportName,
      folder: 'GEE_Af_By_Feature',
      fileNamePrefix: exportName,
      scale: 10,
      region: geometry.bounds(), // 只导出该要素的范围
      maxPixels: 1e13,
      crs: 'EPSG:4326'
    });
  }
  print('已提交 ' + size + ' 个要素的整体导出任务，请检查 Tasks 栏。');
});
