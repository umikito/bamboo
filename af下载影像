// =================================================================
// 2. 核心处理函数：解决 S1 极化冲突与 S2 去云
// =================================================================

// S1 极化对齐函数：强制将所有影像统一为 VV, VH 命名，并进行边缘掩膜
var maskS1 = function(image) {
  var bands = image.bandNames();
  // 无论原始是 VV/VH 还是 HH/HV，均取前两个波段强制重命名
  var aligned = ee.Image(ee.Algorithms.If(
    bands.contains('VV'),
    image.select(['VV', 'VH']),
    image.select([0, 1], ['VV', 'VH'])
  ));
  // 掩膜掉雷达边缘低值噪声
  var edge = aligned.gt(-30.0);
  return aligned.updateMask(edge).float();
};

// S2 去云函数 (使用 QA60 波段)
var maskS2 = function(image) {
  var qa = image.select('QA60');
  var cloudBitMask = 1 << 10;
  var cirrusBitMask = 1 << 11;
  var mask = qa.bitwiseAnd(cloudBitMask).eq(0)
      .and(qa.bitwiseAnd(cirrusBitMask).eq(0));
  return image.updateMask(mask).divide(10000); // 提前归一化
};

// =================================================================
// 3. 建立年度保底图（Gap Filling 模板）
// =================================================================
var s2Bands = ['B2', 'B3', 'B4', 'B8', 'B11', 'B12'];
var s1Bands = ['VV', 'VH'];

var annualS2 = ee.ImageCollection('COPERNICUS/S2_SR_HARMONIZED')
  .filterBounds(roi).filterDate('2020-01-01', '2020-12-31')
  .map(maskS2).median().select(s2Bands);

var annualS1 = ee.ImageCollection('COPERNICUS/S1_GRD')
  .filterBounds(roi).filterDate('2020-01-01', '2020-12-31')
  .filter(ee.Filter.eq('instrumentMode', 'IW'))
  .map(maskS1).median().select(s1Bands);

// =================================================================
// 4. 逐月合成长时序影像堆栈 (12个月 x 8波段)
// =================================================================
var months = ee.List.sequence(1, 12);

var monthlyList = months.map(function(m) {
  var start = ee.Date.fromYMD(2020, m, 1);
  var end = start.advance(1, 'month');
  var monthStr = ee.Number(m).format('%02d');

  // --- S2 模块 ---
  var s2Month = ee.ImageCollection('COPERNICUS/S2_SR_HARMONIZED')
    .filterBounds(roi).filterDate(start, end)
    .map(maskS2).median().select(s2Bands);
  // 用年度底图补全月度空洞 (覆盖模式)
  var s2Final = annualS2.addBands(s2Month, s2Bands, true).select(s2Bands);

  // --- S1 模块 ---
  var s1Month = ee.ImageCollection('COPERNICUS/S1_GRD')
    .filterBounds(roi).filterDate(start, end)
    .filter(ee.Filter.eq('instrumentMode', 'IW'))
    .map(maskS1).median().select(s1Bands);
  // 用年度底图补全月度空洞
  var s1Final = annualS1.addBands(s1Month, s1Bands, true).select(s1Bands);

  // --- 合并并重命名波段 ---
  var combined = s2Final.addBands(s1Final).clip(roi);
  var newNames = combined.bandNames().map(function(n) {
    return ee.String(n).cat('_Month_').cat(monthStr);
  });
  
  return combined.rename(newNames);
});

// 将 List 转为多波段大图
var finalStack = ee.ImageCollection.fromImages(monthlyList).toBands();

// =================================================================
// 5. 地图可视化 (以 1 月份为例)
